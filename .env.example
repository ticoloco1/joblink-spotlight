# Supabase - crie um projeto em https://supabase.com e preencha abaixo
# Para o client Supabase no Next.js (use no código em src/integrations/supabase/client.ts)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_public

# Para rotas/sitemap que ainda usam VITE_* (ex.: app/sitemap.xml/route.ts)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_anon_public
VITE_SUPABASE_PROJECT_ID=SEU_PROJECT_ID

# (opcional) caso você use o project id em algum lugar
NEXT_PUBLIC_SUPABASE_PROJECT_ID=SEU_PROJECT_ID

# Centro dos mini-sites (usado nas vitrines: trustbank.xyz, caixa.xyz, etc.)
# Opcional; padrão: https://jobinlink.com
# VITE_APP_CENTER_URL=https://jobinlink.com
